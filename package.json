    "@types/chai": "^5.2.0",
    "@types/chai-as-promised": "^8.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.10",
    "@types/sinon": "^17.0.3",
    "@types/sinon-chai": "^4.0.0",
    "c8": "^10.1.3",
    "chai": "^5.2.0",
    "chai-as-promised": "^8.0.1",
    "eslint": "^9.39.1",
    "mocha": "^10.8.2",
    "prettier": "^3.4.1",
    "release-it": "^19.2.4",
    "sinon": "^19.0.2",
